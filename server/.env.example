# Hugging Face token (required) — use a token with "Inference > Make calls to the serverless Inference API"
# Create at: https://huggingface.co/settings/tokens (Fine-grained, enable Inference)
HUGGINGFACE_API_KEY=your_key_here

# Server port (default: 5000)
PORT=5000

# Optional: override chat model (default: Qwen/Qwen2.5-7B-Instruct-1M)
# HF_CHAT_MODEL=meta-llama/Llama-3.2-3B-Instruct
